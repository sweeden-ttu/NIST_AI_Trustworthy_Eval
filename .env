# rd-ralph-template + rd-agent-mcp — copy to .env and adjust
OPENAI_BASE_URL=http://localhost:1234/v1
NIST_EVAL_MODEL=unrestricted-knowledge-will-not-refuse-15b

# OpenAI-compatible local server (LM Studio default for this repo)
LM_STUDIO_BASE_URL=http://192.168.0.13:1234/v1
LM_STUDIO_API_KEY=lm-studio

CHAT_MODEL=ibm/granite-4-h-tiny
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Agent repo paths (template submodules)
RD_AGENT_PATH=./agents/rd-agent
ADK_RALPH_PATH=./agents/adk-ralph

# Only true in trusted environments
RD_AGENT_MCP_EXEC_AGENTS=false

# Optional: document where your LM Studio preset JSON lives locally
# LM_STUDIO_PRESET_PATH=~/.lmstudio/config-presets/sgskkssks.preset.json

# Sync LM Studio model ids into Cursor's model picker (quit Cursor first):
#   python3 scripts/sync_cursor_lmstudio_models.py --union-lms --backup
